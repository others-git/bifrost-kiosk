<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.BifrostKiosk" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <!-- Edge-to-edge black surface for the WebView; the WebView paints over it. -->
    <style name="Theme.BifrostKiosk.Fullscreen" parent="Theme.BifrostKiosk">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
</resources>
